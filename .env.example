# ============================================================
# Database
# ============================================================
# PostgreSQL connection string (Neon or local Postgres)
# Get yours from https://console.neon.tech
DATABASE_URL=

# ============================================================
# start.gg API
# ============================================================
# Personal access token for the worker (used for ingestion).
# Generate at https://www.start.gg/admin/profile/developer
STARTGG_TOKEN=

# OAuth credentials for user login.
# Register your app at https://www.start.gg/admin/profile/developer
# under "OAuth Applications" tab.
STARTGG_CLIENT_ID=
STARTGG_CLIENT_SECRET=
STARTGG_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ============================================================
# Encryption
# ============================================================
# AES-256 key in hex (64 chars). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=